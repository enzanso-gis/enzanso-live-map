*.qgs~
*.qgz
*.gpkg-shm
*.gpkg-wal
raw_data/
scripts/

# --- Web Development ---
# もしnpm等を使う場合用
node_modules/
npm-debug.log*

# --- Documentation ---
# ローカルのメモなどは上げない
memo.txt
*.md.bak